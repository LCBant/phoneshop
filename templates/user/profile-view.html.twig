{% extends 'base.html.twig' %}

{% block title %}Profile | {{ app.user.firstName }}{% endblock %}

{% block body %}
<div class="container mt-3">
<h1 class="mb-5">Your Profile</h1>
<p><b>First Name: </b>{{ app.user.firstName }}</p>
<p><b>Last Name: </b>{{ app.user.lastName }}</p>
<p><b>Email: </b>{{ app.user.email }}</p>
<br>
<p>Account created at {{ app.user.createdAt | date('d/m/Y') }}</p>

<a href="{{ path('app_user_edit_profile') }}" class="btn btn-primary fw-bold mt-auto">Edit Profile</a>

</div>
{% endblock %}