<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>

    <body>
        {% block navbar %}
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path("app_home") }}">Navbar</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav">
                <a class="nav-link" href="{{ path("app_home") }}">Home</a>
                <a class="nav-link" href="#">Phones</a>
                <a class="nav-link" href="#">Acessories</a>
                <a class="nav-link" href="#">Deals</a>
                <a class="nav-link" href="#">Repairs</a>
                <a class="nav-link" href="{{ path("app_aboutus") }}">About</a>
                <a class="nav-link" href="{{ path("app_contact") }}">Contact</a>
            </div>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="{{ path("app_register") }}">Register</a>
                <a class="nav-link" href="{{ path("app_login") }}">Login</a>
            </div>
            </div>
            </div>
        </div>
        </nav>
        {% endblock %}
        {% block body %}
        
        {% endblock %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    </body>
</html>
