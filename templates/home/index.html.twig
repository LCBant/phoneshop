{% extends 'base.html.twig' %}

{% block title %}Home | Phoneshop{% endblock %}

{% block body %}
<div class="container-fluid mt-3">
    <h1 class="text-center">This is the homepage.</h1>
</div>
<div class="container">
<h2>Featured Products</h2>
<div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
{% for product in featuredProducts %}
<div class="col">
<div class="card h-100">
  <img src="{{ asset('images/' ~ product.image) }}" class="card-img-top mt-2" style="height: 200px; object-fit: contain;" alt="no-photo">
  <div class="card-body d-flex flex-column">
    <h5 class="card-title" style="min-height: 2rem;">{{ product.name }}</h5>
    <p class="card-text" style="min-height: 3rem;">{{ product.description | slice(0, 80) ~ '...' }}</p>
    <p class="card-text fw-bold">€{{ product.price }}</p>
    <a href="#" class="btn btn-primary w-100 fw-bold mt-auto">View Product</a>
  </div>
</div>
</div>
{% endfor %}
</div>
</div>
{% endblock %}
